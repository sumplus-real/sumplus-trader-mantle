# ── Brain (DeepSeek V4, OpenAI-compatible) ──────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# TODO confirm exact V4 model id with DeepSeek docs (e.g. deepseek-chat / deepseek-v4)
DEEPSEEK_MODEL=deepseek-chat

# ── Hand (Maria secure execution layer, A2A) ────────────────────────
# Maria base, e.g. https://maria.xyz  (prod) — for the demo we point at the smoke-tested instance
MARIA_BASE_URL=
# Bearer for the A2A service auth (_verify_service_bearer)
MARIA_SERVICE_TOKEN=
# Delegated-user JWT: the acting user whose delegation allows action "swap" with our caps
MARIA_DELEGATED_USER_TOKEN=
# How we identify ourselves to Maria
AGENT_ID=sumplus-trading-agent

# ── Identity + wallet (dedicated fresh wallet = 8004 identity = trading wallet) ──
AGENT_WALLET_ADDRESS=
AGENT_WALLET_PRIVATE_KEY=
# ERC-8004 Identity Registry (BSC mainnet). Mantle registry TBD if used.
ERC8004_REGISTRY_BSC=0x8004a169fb4a3325136eb29fa0ceb6d2e539a432

# ── Chains ──────────────────────────────────────────────────────────
MANTLE_RPC=https://rpc.mantle.xyz
BSC_RPC=https://bsc-dataseed.binance.org

# ── Market data ─────────────────────────────────────────────────────
CMC_API_KEY=
